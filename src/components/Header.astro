---
// src/components/Header.astro
---
<header class="bg-[#A898EE] h-20 flex items-center px-6 lg:px-8 z-50 fixed w-full top-0 shadow-md">
  <div class="max-w-7xl mx-auto w-full flex justify-between items-center relative">
    
    <a href="/" class="group absolute left-1/2 -translate-x-1/2">
      <img 
        src="/logo-kinezi.png" 
        alt="Logo Kinezi" 
        class="h-10 w-auto transition-transform duration-300 group-hover:scale-105" 
      />
    </a>
    
    <button class="text-white hover:opacity-80 transition-opacity absolute right-0">
      <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</header>