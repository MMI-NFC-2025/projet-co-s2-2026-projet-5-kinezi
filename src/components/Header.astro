---
// src/components/Header.astro
---
<div class="absolute w-full top-0 z-50 flex flex-col pointer-events-none">
  
  <header class="bg-[#A898EE] h-20 flex items-center px-6 lg:px-16 z-10 relative pointer-events-auto shadow-sm">
    <div class="max-w-[1300px] mx-auto w-full flex justify-between items-center">
      
      <a href="/" class="group flex items-center transition-transform duration-300 hover:scale-105">
        <img 
          src="/logo-kinezi-K.svg" 
          alt="Logo Kinezi" 
          class="h-10 md:h-12 w-auto" 
        />
      </a>
      
      <button id="menu-btn" class="relative w-14 h-14 z-20 pointer-events-auto group cursor-pointer outline-none flex justify-center items-center -mr-2">
        <div class="relative w-10 h-10 flex flex-col justify-center items-end">
          <span class="line-1 absolute h-[3px] w-10 bg-white rounded-full transition-all duration-300 ease-in-out -translate-y-[12px] group-hover:bg-white/90"></span>
          <span class="line-2 absolute h-[3px] w-6 bg-white rounded-full transition-all duration-300 ease-in-out right-0 group-hover:w-10 group-hover:bg-white/90"></span>
          <span class="line-3 absolute h-[3px] w-10 bg-white rounded-full transition-all duration-300 ease-in-out translate-y-[12px] group-hover:bg-white/90"></span>
        </div>
      </button>

    </div>
  </header>

  <div class="w-full leading-[0] -mt-[1px] z-0">
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      viewBox="0 0 1440 120" 
      class="w-full h-auto drop-shadow-xl overflow-visible" 
      preserveAspectRatio="none"
    >
      <path 
        fill="#8C17F8" 
        d="M0,0 L1440,0 L1440,90 C1100,150 400,-30 0,90 Z"
      ></path>

      <path 
        fill="#A898EE" 
        d="M0,0 L1440,0 L1440,40 C1100,120 400,-40 0,60 Z"
        style="filter: drop-shadow(0px 8px 12px rgba(0, 0, 0, 0.15));"
      ></path>
    </svg>
  </div>
</div>

<style>
  /* Animation pour transformer les lignes en croix (X) */
  #menu-btn.is-active .line-1 {
    transform: translateY(0) rotate(45deg);
  }
  #menu-btn.is-active .line-2 {
    opacity: 0;
    width: 0;
  }
  #menu-btn.is-active .line-3 {
    transform: translateY(0) rotate(-45deg);
  }
</style>