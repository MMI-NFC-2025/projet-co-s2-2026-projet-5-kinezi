---
// src/components/Header.astro
---
<div class="absolute w-full top-0 z-50 flex flex-col pointer-events-none">
  
  <header class="bg-[#A898EE] h-20 flex items-center px-6 lg:px-16 z-10 relative pointer-events-auto shadow-sm">
    <div class="max-w-[1300px] mx-auto w-full flex justify-between items-center">
      
      <a href="/" class="group flex items-center transition-transform duration-300 hover:scale-105">
        <img 
          src="/logo-kinezi-K.svg" 
          alt="Logo Kinezi" 
          class="h-10 md:h-12 w-auto" 
        />
      </a>
      
      <div class="flex items-center gap-3 md:gap-5">
        
        <a 
          href="/login" 
          class="hidden sm:block border-2 border-white text-white font-bold text-sm px-4 py-2 rounded-full transition-all duration-300 hover:bg-white/10 active:scale-95"
        >
          Se connecter
        </a>

        <a 
          href="/register" 
          class="bg-white text-[#A898EE] font-bold text-sm md:text-base px-5 py-2.5 rounded-full shadow-[0_4px_12px_rgba(0,0,0,0.1)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(0,0,0,0.15)] active:scale-95"
        >
          Créer un compte
        </a>

        <button id="menu-btn" class="relative w-12 h-12 z-20 pointer-events-auto group cursor-pointer outline-none flex justify-center items-center -mr-2">
          <div class="relative w-8 h-8 flex flex-col justify-center items-end">
            <span class="line-1 absolute h-[3px] w-8 bg-white rounded-full transition-all duration-300 ease-in-out -translate-y-[10px] group-hover:bg-white/90"></span>
            <span class="line-2 absolute h-[3px] w-5 bg-white rounded-full transition-all duration-300 ease-in-out right-0 group-hover:w-8 group-hover:bg-white/90"></span>
            <span class="line-3 absolute h-[3px] w-8 bg-white rounded-full transition-all duration-300 ease-in-out translate-y-[10px] group-hover:bg-white/90"></span>
          </div>
        </button>

      </div>

    </div>
  </header>

  <div class="w-full leading-[0] -mt-[1px] z-0">
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      viewBox="0 0 1440 120" 
      class="w-full h-auto drop-shadow-xl overflow-visible" 
      preserveAspectRatio="none"
    >
      <path 
        fill="#8C17F8" 
        d="M0,0 L1440,0 L1440,90 C1100,150 400,-30 0,90 Z"
      ></path>

      <path 
        fill="#A898EE" 
        d="M0,0 L1440,0 L1440,40 C1100,120 400,-40 0,60 Z"
        style="filter: drop-shadow(0px 8px 12px rgba(0, 0, 0, 0.15));"
      ></path>
    </svg>
  </div>
</div>

<style>
  #menu-btn.is-active .line-1 {
    transform: translateY(0) rotate(45deg);
  }
  #menu-btn.is-active .line-2 {
    opacity: 0;
    width: 0;
  }
  #menu-btn.is-active .line-3 {
    transform: translateY(0) rotate(-45deg);
  }
</style>