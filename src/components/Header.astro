---
// src/components/Header.astro
---
<div class="fixed w-full top-0 z-50 flex flex-col pointer-events-none">
  
  <header class="bg-[#A898EE] h-14 flex items-center px-6 lg:px-8 z-10 relative pointer-events-auto shadow-sm">
    <div class="max-w-7xl mx-auto w-full flex justify-between items-center relative">
      
      <a href="/" class="group absolute left-1/2 -translate-x-1/2">
        <img 
          src="/logo-kinezi.png" 
          alt="Logo Kinezi" 
          class="h-10 md:h-12 w-auto transition-transform duration-300 group-hover:scale-105" 
        />
      </a>
      
      <button class="text-white hover:opacity-80 transition-opacity absolute right-0">
        <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </header>

  <div class="w-full leading-[0] -mt-[1px] z-0">
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      viewBox="0 0 1440 120" 
      class="w-full h-auto drop-shadow-xl overflow-visible" 
      preserveAspectRatio="none"
    >
      <path 
        fill="#8C17F8" 
        d="M0,0 L1440,0 L1440,90 C1100,150 400,-30 0,90 Z"
      ></path>

      <path 
        fill="#A898EE" 
        d="M0,0 L1440,0 L1440,40 C1100,120 400,-40 0,60 Z"
        style="filter: drop-shadow(0px 8px 12px rgba(0, 0, 0, 0.15));"
      ></path>
    </svg>
  </div>
</div>