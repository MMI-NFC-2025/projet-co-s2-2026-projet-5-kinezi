---
// src/components/Menu.astro
---

<div 
  id="menu-overlay" 
  class="fixed inset-0 bg-black/40 z-[100] opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<aside 
  id="side-menu" 
  class="fixed top-0 left-0 w-[85%] max-w-[350px] h-full bg-[#A898EE] rounded-r-[40px] shadow-2xl z-[101] transform -translate-x-full transition-transform duration-300 flex flex-col py-12 overflow-y-auto"
>
  <div class="flex items-center gap-6 px-8 mb-12">
    <div class="w-20 h-20 rounded-full border-[3px] border-white flex items-center justify-center flex-shrink-0">
      <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
      </svg>
    </div>
    <span class="text-white font-black text-xl leading-tight">Thomas<br/>Perruchot</span>
  </div>

  <nav class="flex-1 flex flex-col gap-2">
    
    <a href="/" class="flex items-center gap-5 py-4 px-8 bg-white text-[#A898EE] w-[90%] rounded-r-full shadow-sm transition-transform hover:scale-[1.02]">
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"></path>
      </svg>
      <span class="font-bold text-lg">Accueil</span>
    </a>

    <a href="/profil" class="flex items-center gap-5 py-4 px-8 text-white w-[90%] rounded-r-full hover:bg-white/10 transition-colors">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
      </svg>
      <span class="font-medium text-lg">Profil</span>
    </a>

    <a href="/exercices" class="flex items-center gap-5 py-4 px-8 text-white w-[90%] rounded-r-full hover:bg-white/10 transition-colors">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
      </svg>
      <span class="font-medium text-lg">Exercices</span>
    </a>

    <a href="/bibliotheque" class="flex items-center gap-5 py-4 px-8 text-white w-[90%] rounded-r-full hover:bg-white/10 transition-colors">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
      </svg>
      <span class="font-medium text-lg">Bibliothèque de leçons</span>
    </a>

    <a href="/favoris" class="flex items-center gap-5 py-4 px-8 text-white w-[90%] rounded-r-full hover:bg-white/10 transition-colors">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
      </svg>
      <span class="font-medium text-lg">Leçons préférées</span>
    </a>

    <div class="h-[2px] bg-white/30 w-[70%] mx-auto my-4 rounded-full"></div>

    <a href="/parametres" class="flex items-center gap-5 py-4 px-8 text-white w-[90%] rounded-r-full hover:bg-white/10 transition-colors">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      <span class="font-medium text-lg">Paramètres</span>
    </a>

    <a href="/aide" class="flex items-center gap-5 py-4 px-8 text-white w-[90%] rounded-r-full hover:bg-white/10 transition-colors">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span class="font-medium text-lg">Aide</span>
    </a>

    <div class="h-[2px] bg-white/30 w-[70%] mx-auto my-4 rounded-full"></div>

    <a href="/deconnexion" class="flex items-center gap-5 py-4 px-8 text-white w-[90%] rounded-r-full hover:bg-white/10 transition-colors mt-auto">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
      </svg>
      <span class="font-medium text-lg">Déconnexion</span>
    </a>

  </nav>
</aside>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const sideMenu = document.getElementById('side-menu');
  const menuOverlay = document.getElementById('menu-overlay');

  function toggleMenu() {
    // Si le menu est fermé (transformé à -100%)
    if (sideMenu.classList.contains('-translate-x-full')) {
      // On ouvre
      sideMenu.classList.remove('-translate-x-full');
      sideMenu.classList.add('translate-x-0');
      menuOverlay.classList.remove('opacity-0', 'pointer-events-none');
      menuOverlay.classList.add('opacity-100', 'pointer-events-auto');
    } else {
      // On ferme
      sideMenu.classList.add('-translate-x-full');
      sideMenu.classList.remove('translate-x-0');
      menuOverlay.classList.remove('opacity-100', 'pointer-events-auto');
      menuOverlay.classList.add('opacity-0', 'pointer-events-none');
    }
  }

  // Écouteur sur le bouton du Header
  if (menuBtn) {
    menuBtn.addEventListener('click', toggleMenu);
  }

  // Écouteur sur le fond gris pour fermer le menu en cliquant à côté
  if (menuOverlay) {
    menuOverlay.addEventListener('click', toggleMenu);
  }
</script>