---
// src/components/Footer.astro
---

<footer class="relative w-full mt-20 flex flex-col">
  <div class="w-full leading-[0] mb-[-1px] rotate-180">
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      viewBox="0 0 1440 120" 
      class="w-full h-auto drop-shadow-[0_-10px_15px_rgba(0,0,0,0.1)] overflow-visible" 
      preserveAspectRatio="none"
    >
      <path 
        fill="#8C17F8" 
        d="M0,0 L1440,0 L1440,90 C1100,150 400,-30 0,90 Z"
      ></path>

      <path 
        fill="#A898EE" 
        d="M0,0 L1440,0 L1440,40 C1100,120 400,-40 0,60 Z"
        style="filter: drop-shadow(0px -8px 12px rgba(0, 0, 0, 0.15));"
      ></path>
    </svg>
  </div>

  <footer class="bg-[#A898EE] pt-12 pb-16 px-6 lg:px-8 relative z-10 text-white">
    <div class="max-w-7xl mx-auto w-full">
      
      <div class="text-center mb-20">
        <h2 class="text-3xl md:text-5xl font-black tracking-tight">
          Brisez le silence, apprenez à signer.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-end">
        
        <div class="flex flex-col gap-6">
          <div class="space-y-1 text-sm font-medium opacity-90">
            <p>kinezi@gmail.com</p>
            <p>06 00 00 00 00</p>
            <div class="pt-4">
              <p>4 Pl. Lucien Tharradin</p>
              <p>25200 Montbéliard</p>
              <p>France</p>
            </div>
          </div>
          
          <div class="flex items-center mt-4">
            <img 
              src="/logo-kinezi.png" 
              alt="Logo Kinezi" 
              class="h-12 w-auto brightness-0 invert transition-transform hover:scale-110 duration-300" 
            />
          </div>
        </div>

        <div class="text-center pb-2">
          <a href="/mentions" class="text-sm font-bold opacity-80 hover:opacity-100 transition-opacity underline underline-offset-4">
            Mentions légales
          </a>
        </div>

        <div class="flex justify-center md:justify-end gap-8 items-center">
          
          <a href="https://instagram.com/kinezi" target="_blank" class="group">
            <img 
              src="/instagram.svg" 
              alt="Instagram Kinezi" 
              class="w-8 h-8 transition-all duration-300 group-hover:scale-125 group-hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)]" 
            />
          </a>

          <a href="https://tiktok.com/@kinezi" target="_blank" class="group">
            <img 
              src="/tiktok.svg" 
              alt="TikTok Kinezi" 
              class="w-8 h-8 transition-all duration-300 group-hover:scale-125 group-hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)]" 
            />
          </a>

          <a href="https://youtube.com/kinezi" target="_blank" class="group">
            <img 
              src="/youtube.svg" 
              alt="YouTube Kinezi" 
              class="w-8 h-8 transition-all duration-300 group-hover:scale-125 group-hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)]" 
            />
          </a>

          <a href="https://facebook.com/kinezi" target="_blank" class="group">
            <img 
              src="/facebook.svg" 
              alt="Facebook Kinezi" 
              class="w-8 h-8 transition-all duration-300 group-hover:scale-125 group-hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)]" 
            />
          </a>
          
        </div>

      </div>
    </div>
  </footer>
</footer>