---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Menu from '../components/Menu.astro';
---

<Layout title="Kinezi | Brisez le silence, apprenez à signer.">
    <Header />
    <Menu />

    <main class="relative min-h-screen bg-white pt-[200px] pb-16 overflow-hidden">
        
        <div class="absolute top-1/4 -right-20 w-[600px] h-[600px] bg-[#8C17F8]/5 rounded-full blur-[120px] pointer-events-none"></div>

        <div class="max-w-[1300px] mx-auto px-8 lg:px-16 flex flex-col md:flex-row md:items-end justify-between gap-12 lg:gap-20 relative z-10">
            
            <div class="flex-1 text-center md:text-left flex flex-col items-center md:items-start animate-fade-in pb-4">
                
                <h1 class="text-4xl md:text-5xl lg:text-[4rem] font-bold leading-tight text-gray-900">
                    <span class="inline-block whitespace-nowrap">Brisez le silence,</span><br />
                    <span class="inline-block whitespace-nowrap text-[#8C17F8]">apprenez à signer.</span>
                </h1>

                <a href="#discover" class="inline-block mt-20 bg-gradient-to-br from-[#8C17F8] to-[#7a14da] text-white font-bold text-3xl md:text-4xl px-12 py-6 rounded-full shadow-[0_10px_25px_rgba(140,23,248,0.25)] hover:shadow-[0_15px_35px_rgba(140,23,248,0.35)] transition-all transform hover:-translate-y-1 active:scale-95 text-center">
                    Découvrez nous !
                </a>
                
            </div>

            <div class="flex-1 flex justify-center z-0 w-full md:-translate-x-12 pb-4">
                
                <div class="relative w-full max-w-[340px] flex flex-col items-center">
                    
                    <img 
                        src="/mockup-telephone.png" 
                        alt="Interface de l'application Kinezi" 
                        class="w-full h-auto object-contain pointer-events-none animate-float relative z-10 mb-8" 
                    />

                    <div class="absolute bottom-[0px] w-[80%] h-12 bg-black/15 rounded-[100%] blur-[18px] animate-shadow-pulse z-0"></div>
                    <div class="absolute bottom-[5px] w-[55%] h-4 bg-black/35 rounded-[100%] blur-[6px] animate-shadow-pulse z-0"></div>
                </div>
            </div>

        </div>
    </main>

    <section id="discover" class="pt-12 pb-24 bg-white relative z-10 border-b border-gray-100">
        <div class="max-w-[1300px] mx-auto px-8 lg:px-16">
            <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 text-center mb-16 tracking-tight">
                Kinezi, qu'est ce que c'est ?
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
                <div>
                    <h3 class="text-2xl font-bold text-[#8C17F8] mb-4">Kinezi ?</h3>
                    <p class="text-gray-700 leading-relaxed text-lg">
                        Kinezi est une web app ouverte à tous, destinée aux personnes souhaitant découvrir, comprendre et apprendre la Langue des Signes Française afin de pouvoir communiquer avec les personnes sourdes, malentendantes ou muettes.
                    </p>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-[#8C17F8] mb-4">Une expérience ludique !</h3>
                    <p class="text-gray-700 leading-relaxed text-lg">
                        Grâce à une approche basée sur la gamification, Kinezi rend l'apprentissage de la LSF plus accessible, ludique et motivant. Le jeu devient un levier pédagogique central.
                    </p>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-[#8C17F8] mb-4">Un pas vers l'inclusivité...</h3>
                    <p class="text-gray-700 leading-relaxed text-lg">
                        La plateforme vise à sensibiliser le grand public aux enjeux de la communication inclusive. En facilitant l'apprentissage, Kinezi contribue à réduire les barrières.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section id="stats" class="py-24 bg-[#8C17F8] text-white relative z-10">
        <div class="max-w-[1300px] mx-auto px-8 lg:px-16 relative z-10">
            <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-16 max-w-[1100px] mx-auto">
                <div class="flex flex-col items-center gap-6 group transition-transform hover:scale-105">
                    <img src="/icone-profile-landing-page.png" alt="Icône de profil de Kinezi" class="w-32 h-32 md:w-48 md:h-48 object-contain" />
                    <span class="text-4xl md:text-5xl font-black text-white tracking-tighter">300 000</span>
                </div>
                <div class="flex-1">
                    <p class="text-xl md:text-2xl text-white leading-relaxed font-medium">
                        Ce chiffre représente le nombre de personnes en France souffrant d'une surdité sévère à profonde. Vous en connaissez peut-être déjà un(e), ou vous en rencontrerez un(e) dans votre vie. Alors qu'attendez-vous pour apprendre les bases ?
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section id="team" class="pt-12 pb-24 bg-gradient-to-b from-[#8C17F8] to-white to-100% relative z-10 -mt-20">
        <div class="max-w-[1300px] mx-auto px-8 lg:px-16 relative z-10">
            <h2 class="text-4xl md:text-5xl font-extrabold text-white text-center mb-20 tracking-tight">
                Notre équipe
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-16 lg:gap-12">
                <div class="flex flex-col items-center text-center group">
                    <div class="relative w-48 h-48 md:w-60 md:h-60 mb-6 rounded-full p-1 border-2 border-white/50 group-hover:border-white transition-all duration-300">
                        <div class="w-full h-full rounded-full overflow-hidden">
                            <img src="/lilian-rond.png" alt="Lilian Maitre" class="w-full h-full object-cover scale-[1.1] object-center transform group-hover:scale-[1.2] transition-transform duration-500" />
                        </div>
                    </div>
                    <h3 class="text-2xl font-bold text-white">Lilian Maitre</h3>
                    <p class="text-white/80 font-medium">Élève de BUT MMI</p>
                    <a href="mailto:lilianmaitre@kinezi.fr" class="text-white underline underline-offset-4 hover:text-white/70 transition-colors mt-2">lilianmaitre@kinezi.fr</a>
                </div>

                <div class="flex flex-col items-center text-center group">
                    <div class="relative w-48 h-48 md:w-60 md:h-60 mb-6 rounded-full p-1 border-2 border-white/50 group-hover:border-white transition-all duration-300">
                        <div class="w-full h-full rounded-full overflow-hidden">
                            <img src="/ewan-rond.png" alt="Ewan Menigoz" class="w-full h-full object-cover scale-[1.1] object-center transform group-hover:scale-[1.2] transition-transform duration-500" />
                        </div>
                    </div>
                    <h3 class="text-2xl font-bold text-white">Ewan Menigoz</h3>
                    <p class="text-white/80 font-medium">Élève de BUT MMI</p>
                    <a href="mailto:ewanmenigoz@kinezi.fr" class="text-white underline underline-offset-4 hover:text-white/70 transition-colors mt-2">ewanmenigoz@kinezi.fr</a>
                </div>

                <div class="flex flex-col items-center text-center group">
                    <div class="relative w-48 h-48 md:w-60 md:h-60 mb-6 rounded-full p-1 border-2 border-white/50 group-hover:border-white transition-all duration-300">
                        <div class="w-full h-full rounded-full overflow-hidden">
                            <img src="/enzo-rond.png" alt="Enzo Hillairet" class="w-full h-full object-cover scale-[1.1] object-center transform group-hover:scale-[1.2] transition-transform duration-500" />
                        </div>
                    </div>
                    <h3 class="text-2xl font-bold text-white">Enzo Hillairet</h3>
                    <p class="text-white/80 font-medium">Élève de BUT MMI</p>
                    <a href="mailto:enzohillairet@kinezi.fr" class="text-white underline underline-offset-4 hover:text-white/70 transition-colors mt-2">enzohillairet@kinezi.fr</a>
                </div>
            </div>
        </div>
    </section>

    <section class="pb-32 bg-white relative z-10">
        <div class="max-w-[1300px] mx-auto px-8 lg:px-16">
            
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 text-center mb-12 tracking-tight">
                Notre abonnement pour une expérience plus poussée !
            </h2>

            <div class="max-w-[1150px] mx-auto bg-gray-100 rounded-[24px] overflow-hidden flex flex-col md:flex-row shadow-lg transition-transform hover:scale-[1.01] duration-300 border border-gray-200">
                
                <div class="bg-[#8C17F8] py-12 px-12 flex items-center justify-center md:w-[280px] self-stretch flex-shrink-0">
                    <img src="/logo-kinezi-K.svg" alt="Logo Kinezi K" class="w-32 h-32 md:w-36 md:h-36 object-contain" />
                </div>

                <div class="p-8 md:px-12 md:py-8 flex-1 flex flex-col md:flex-row md:items-center justify-between gap-8">
                    
                    <div class="flex flex-col justify-center flex-shrink-0">
                        <div class="flex items-center gap-4 mb-2">
                            <span class="text-2xl font-black text-gray-900">10€/mois</span>
                            <div class="flex gap-2">
                                <img src="/infini.svg" alt="Illimité" class="w-7 h-7 object-contain" />
                                <img src="/couronne.svg" alt="Premium" class="w-7 h-7 object-contain" />
                                <img src="/video.svg" alt="Badge" class="w-7 h-7 object-contain" />
                            </div>
                        </div>

                        <h3 class="text-3xl font-black text-gray-900 leading-tight tracking-tighter">
                            Abonnement premium
                        </h3>
                    </div>

                    <p class="text-gray-700 text-lg md:text-xl max-w-[380px] leading-snug font-medium">
                        Pas de pub, tentatives illimitées, un badge premium, et bien plus encore...
                    </p>

                    <button class="bg-[#8C17F8] text-white font-bold py-3.5 px-10 text-lg rounded-full hover:bg-[#7a14da] transition-all whitespace-nowrap shadow-md active:scale-95 flex-shrink-0">
                        S'abonner
                    </button>
                </div>

            </div>
        </div>
    </section>

    <section class="pb-40 bg-white relative z-10">
        <div class="max-w-[1300px] mx-auto px-8 lg:px-16 text-center">
            <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-10 tracking-tight">
                Rejoignez nous !
            </h2>
            <a 
                href="/register" 
                class="inline-block bg-[#8C17F8] text-white font-black text-2xl md:text-3xl px-16 py-6 rounded-full shadow-[0_15px_35px_rgba(140,23,248,0.3)] hover:shadow-[0_20px_45px_rgba(140,23,248,0.4)] transition-all transform hover:-translate-y-1 active:scale-95 animate-pulse-subtle"
            >
                Je rejoins !
            </a>
        </div>
    </section>

    <Footer />
</Layout>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
    }
    .animate-float {
        animation: float 8s ease-in-out infinite;
    }

    @keyframes shadowPulse {
        0%, 100% { transform: scale(1); opacity: 0.6; }
        50% { transform: scale(0.8); opacity: 0.2; }
    }
    .animate-shadow-pulse {
        animation: shadowPulse 8s ease-in-out infinite;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
        animation: fadeIn 0.8s ease-out forwards;
    }

    @keyframes pulse-subtle {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.03); }
    }
    .animate-pulse-subtle {
        animation: pulse-subtle 3s ease-in-out infinite;
    }
</style>