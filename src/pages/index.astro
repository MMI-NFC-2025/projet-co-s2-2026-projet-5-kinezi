---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro'; // Assure-toi d'avoir créé ce fichier avec le code précédent
---

<Layout title="Kinezi | Apprendre la LSF en jouant">
  <Header />

  <main class="pt-24 min-h-screen relative overflow-hidden">
    
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[600px] h-[600px] bg-kinezi-violet/10 rounded-full blur-3xl -z-10"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-[500px] h-[500px] bg-blue-400/10 rounded-full blur-3xl -z-10"></div>

    <section class="max-w-7xl mx-auto px-6 lg:px-8 py-12 sm:py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        
        <div class="space-y-8 text-center lg:text-left">
          
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-100 shadow-sm text-kinezi-violet text-sm font-bold">
            <span class="flex h-2.5 w-2.5 rounded-full bg-green-500 animate-pulse"></span>
            Intelligence Artificielle intégrée
          </div>
          
          <h1 class="font-spartan text-5xl sm:text-6xl lg:text-7xl font-extrabold text-kinezi-bleu leading-[1.1]">
            Brisons le silence, <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-kinezi-violet to-purple-400">en jouant.</span>
          </h1>
          
          <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto lg:mx-0">
            Kinezi est la première webapp qui utilise votre caméra pour corriger vos signes en temps réel. Des leçons de 10 minutes, des mini-jeux, et une immersion totale.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start pt-4">
            <a href="/register" class="bg-kinezi-violet text-white px-8 py-4 rounded-full font-bold text-lg shadow-xl shadow-kinezi-violet/25 transition-all transform hover:scale-105 hover:bg-opacity-90 flex justify-center items-center gap-2">
              Commencer l'aventure
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
          </div>
        </div>
        
        <div class="relative w-full flex justify-center lg:justify-end mt-12 lg:mt-0">
          
          <div class="relative w-full max-w-[500px] rounded-[2rem] overflow-hidden shadow-2xl border-4 border-white transform lg:-rotate-2 hover:rotate-0 transition-transform duration-500 bg-white">
            
            <img 
              src="/image_995544.jpg" 
              alt="Interface de l'application Kinezi" 
              class="w-full h-auto object-cover"
            />
            
          </div>
          
          <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-2xl shadow-xl flex items-center gap-4 border border-gray-50 hidden md:flex">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-500 text-2xl">
              ✓
            </div>
            <div>
              <p class="font-bold text-kinezi-bleu text-sm font-spartan">Signe validé !</p>
              <p class="text-xs text-gray-500">+50 XP</p>
            </div>
          </div>

        </div>

      </div>
    </section>
  </main>
</Layout>