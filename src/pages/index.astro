---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Kinezi | Brisez le silence, apprenez à signer.">
	<Header />

	<main class="relative min-h-screen bg-[linear-gradient(90deg,#8C17F8_13%,#FFFFFF_100%)] pt-40 pb-16">
		
		<div class="max-w-[1400px] mx-auto pl-6 pr-6 lg:pl-12 lg:pr-8 flex flex-col md:flex-row items-center md:justify-between">
			
			<div class="flex-1 text-center md:text-left z-10 md:-ml-4">
				
				<div class="bg-white/20 backdrop-blur-sm text-white text-sm font-bold px-4 py-1.5 rounded-full inline-block mb-6 md:mb-8 shadow-sm">
					Intelligence Artificielle intégrée
				</div>

				<h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight text-white max-w-5xl mx-auto md:mx-0 whitespace-nowrap">
					Brisez le silence, 
					<br>apprenez à signer.<br>
				</h1>

				<a href="#discover" class="inline-block mt-10 bg-white text-[#8C17F8] font-bold text-xl px-10 py-5 rounded-full shadow-lg hover:shadow-2xl transition-all transform hover:-translate-y-1">
					Découvrez nous !
				</a>
			</div>

			<div class="flex-1 mt-16 md:mt-0 flex justify-center md:justify-end z-0 relative">
				<div class="relative w-72 h-[600px] md:h-auto group">
					<img 
						src="/image_995544.jpg" 
						alt="Interface de l'application Kinezi" 
						class="w-full h-auto object-cover rounded-[2rem] shadow-2xl shadow-purple-900/20 transform md:rotate-[-6deg] md:scale-110 transition-transform duration-500 group-hover:rotate-0" 
					/>
				</div>
			</div>

		</div>
	</main>

</Layout>